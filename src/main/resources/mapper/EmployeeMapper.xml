<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mcp.mapper.EmployeeMapper">

    <resultMap id="EmployeeResultMap" type="com.example.mcp.entity.Employee">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="position" column="position"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 查询所有员工 -->
    <select id="selectAll" resultMap="EmployeeResultMap">
        SELECT id, name, position, create_time
        FROM employees
        ORDER BY name
    </select>

    <!-- 根据姓名查询员工 -->
    <select id="selectByName" resultMap="EmployeeResultMap">
        SELECT id, name, position, create_time
        FROM employees
        WHERE name = #{name}
        LIMIT 1
    </select>

    <!-- 插入员工 -->
    <insert id="insert" parameterType="com.example.mcp.entity.Employee" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO employees (name, position, create_time)
        VALUES (#{name}, #{position}, #{createTime})
    </insert>

    <!-- 更新员工岗位 -->
    <update id="updatePosition">
        UPDATE employees
        SET position = #{position}
        WHERE name = #{name}
    </update>

    <!-- 删除员工 -->
    <delete id="deleteById">
        DELETE FROM employees
        WHERE id = #{id}
    </delete>

</mapper>
